tap "buo/cask-upgrade"
tap "mas-cli/tap"
tap "github/gh"
tap "git-friendly/git-friendly"
tap "oven-sh/bun"

cask_args appdir: "/Applications"

# Zsh Essentials
brew "zsh"
brew "starship"
brew "zsh-completions"
brew "zsh-autosuggestions"
brew "zsh-syntax-highlighting"

# System tools
brew "uutils-coreutils"
brew "uutils-findutils"
brew "autoconf"
brew "pkg-config"
brew "chezmoi"
brew "mackup"
brew "mas"
cask "ilya-birman-typography-layout"

# Utils
brew "bat", args: ["build-from-source"]
brew "micro"
brew "cloc"
brew "pwgen"
brew "vips"

# Compression tools
brew "ouch"
brew "p7zip"

# Filesystem tools
brew "fd"
brew "fzf"
brew "tree"
brew "grex"
brew "ripgrep"
brew "eza"

# Network tools
brew "wget"
brew "curl"
brew "hurl"
brew "httpie"
brew "dog"

# Git
brew "gh"
brew "gist"
brew "git"
brew "git-delta"
brew "git-extras"
brew "git-flow"
brew "git-fresh"
brew "git-recent"
brew "git-when-merged"
brew "git-friendly/git-friendly/git-friendly"

# Node.js
brew "fnm"
brew "deno"
brew "oven-sh/bun/bun"

# Java
cask "java" unless system "/usr/libexec/java_home --failfast"

# Python
brew "python"
brew "uv"

# Rust
brew "rust"

# GUI tools
brew "lazygit"
brew "lazyssh"
brew "htop"
brew "mactop"
brew "midnight-commander"
brew "ncdu"
brew "yazi"

# AI tools
brew "codex"
cask "claude-code"

# Applications
cask "container"
cask "google-chrome"
cask "firefox"
cask "cmux"
cask "zed"

# Fonts
cask "font-fira-code"
cask "font-fira-code-nerd-font"
cask "font-powerline-symbols"
